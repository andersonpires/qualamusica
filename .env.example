# Banco de dados
DB_HOST=localhost
DB_NAME=qualamusica
DB_USER=root
DB_PASS=
DB_PORT=3306

# Aplicação
APP_NAME="Qual é a música?"
APP_ENV=development
APP_DEBUG=true

# URLs e base path por ambiente
# Override opcional: APP_URL e APP_BASE_PATH
APP_LOCAL_URL=http://localhost/qualamusica
APP_PROD_URL=https://qualamusica.iteva.com.br
APP_LOCAL_BASE_PATH=/qualamusica
APP_PROD_BASE_PATH=/

# Segurança
ADMIN_SECRET_KEY=trocar_este_valor
ADMIN_PANEL_PASSWORD=trocar_esta_senha

# E-mail (SMTP legado - opcional)
MAIL_HOST=smtp.office365.com
MAIL_PORT=587
MAIL_ENCRYPTION=tls
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_NAME="Qual é a música?"
MAIL_DEBUG=false

# E-mail (Microsoft Graph API / OAuth2)
GRAPH_TENANT_ID=
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=
GRAPH_SENDER_EMAIL=
GRAPH_TIMEOUT_SECONDS=20
GRAPH_DEBUG=false
